{
    "$schema":  "./node_modules/@angular/cli/lib/config/schema.json",
    "version":  1,
    "cli":  {
                "packageManager":  "npm"
            },
    "newProjectRoot":  "projects",
    "projects":  {
                     "bodegasys-frontend":  {
                                                "projectType":  "application",
                                                "schematics":  {

                                                               },
                                                "root":  "",
                                                "sourceRoot":  "src",
                                                "prefix":  "app",
                                                "architect":  {
                                                                  "build":  {
                                                                                "builder":  "@angular/build:application",
                                                                                "options":  {
                                                                                                "browser":  "src/main.ts",
                                                                                                "tsConfig":  "tsconfig.app.json",
                                                                                                "assets":  [
                                                                                                               {
                                                                                                                   "glob":  "**/*",
                                                                                                                   "input":  "public"
                                                                                                               }
                                                                                                           ],
                                                                                                "styles":  [
                                                                                                               "src/styles.css"
                                                                                                           ],
                                                                                                "security":  {
                                                                                                                 "allowedHosts":  [

                                                                                                                                  ]
                                                                                                             },
                                                                                                "allowedCommonJsDependencies":  [
                                                                                                                                    "jspdf",
                                                                                                                                    "jspdf-autotable",
                                                                                                                                    "canvg",
                                                                                                                                    "rgbcolor",
                                                                                                                                    "raf",
                                                                                                                                    "core-js"
                                                                                                                                ],
                                                                                                "budgets":  [
                                                                                                                {
                                                                                                                    "type":  "initial",
                                                                                                                    "maximumWarning":  "1.50mb",
                                                                                                                    "maximumError":  "2.00mb"
                                                                                                                },
                                                                                                                {
                                                                                                                    "type":  "anyComponentStyle",
                                                                                                                    "maximumWarning":  "6kb",
                                                                                                                    "maximumError":  "10kb"
                                                                                                                }
                                                                                                            ],
                                                                                                "polyfills":  [
                                                                                                                  "zone.js"
                                                                                                              ]
                                                                                            },
                                                                                "configurations":  {
                                                                                                       "production":  {
                                                                                                                          "budgets":  [
                                                                                                                                          {
                                                                                                                                              "type":  "initial",
                                                                                                                                              "maximumWarning":  "1.50mb",
                                                                                                                                              "maximumError":  "2.00mb"
                                                                                                                                          },
                                                                                                                                          {
                                                                                                                                              "type":  "anyComponentStyle",
                                                                                                                                              "maximumWarning":  "6kb",
                                                                                                                                              "maximumError":  "10kb"
                                                                                                                                          }
                                                                                                                                      ],
                                                                                                                          "outputHashing":  "all",
                                                                                                                          "allowedCommonJsDependencies":  [
                                                                                                                                                              "jspdf",
                                                                                                                                                              "jspdf-autotable",
                                                                                                                                                              "canvg",
                                                                                                                                                              "rgbcolor",
                                                                                                                                                              "raf",
                                                                                                                                                              "core-js"
                                                                                                                                                          ]
                                                                                                                      },
                                                                                                       "development":  {
                                                                                                                           "optimization":  false,
                                                                                                                           "extractLicenses":  false,
                                                                                                                           "sourceMap":  true
                                                                                                                       }
                                                                                                   },
                                                                                "defaultConfiguration":  "production"
                                                                            },
                                                                  "serve":  {
                                                                                "builder":  "@angular/build:dev-server",
                                                                                "configurations":  {
                                                                                                       "production":  {
                                                                                                                          "buildTarget":  "bodegasys-frontend:build:production"
                                                                                                                      },
                                                                                                       "development":  {
                                                                                                                           "buildTarget":  "bodegasys-frontend:build:development"
                                                                                                                       }
                                                                                                   },
                                                                                "defaultConfiguration":  "development"
                                                                            },
                                                                  "test":  {
                                                                               "builder":  "@angular/build:unit-test"
                                                                           }
                                                              }
                                            }
                 }
}
